      {
        "name": "Campaigns",
        "item": [
          {
            "name": "Get All Campaigns",
            "request": {
              "method": "GET",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{token}}"
                }
              ],
              "url": {
                "raw": "http://localhost:5000/api/campaigns?page=1&limit=10&status=active",
                "protocol": "http",
                "host": ["localhost"],
                "port": "5000",
                "path": ["api", "campaigns"],
                "query": [
                  {
                    "key": "page",
                    "value": "1"
                  },
                  {
                    "key": "limit",
                    "value": "10"
                  },
                  {
                    "key": "status",
                    "value": "active"
                  }
                ]
              }
            }
          },
          {
            "name": "Get Campaign by ID",
            "request": {
              "method": "GET",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{token}}"
                }
              ],
              "url": {
                "raw": "http://localhost:5000/api/campaigns/1",
                "protocol": "http",
                "host": ["localhost"],
                "port": "5000",
                "path": ["api", "campaigns", "1"]
              }
            }
          },
          {
            "name": "Create Campaign",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                },
                {
                  "key": "Authorization",
                  "value": "Bearer {{token}}"
                }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"name\": \"Summer Sale 2024\",\n  \"client\": \"Nike\",\n  \"status\": \"active\",\n  \"budget\": 75000,\n  \"spend\": 25000,\n  \"impressions\": 1200000,\n  \"clicks\": 36000,\n  \"conversions\": 1080\n}"
              },
              "url": {
                "raw": "http://localhost:5000/api/campaigns",
                "protocol": "http",
                "host": ["localhost"],
                "port": "5000",
                "path": ["api", "campaigns"]
              }
            }
          },
          {
            "name": "Update Campaign",
            "request": {
              "method": "PUT",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                },
                {
                  "key": "Authorization",
                  "value": "Bearer {{token}}"
                }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"spend\": 68000,\n  \"clicks\": 52000,\n  \"impressions\": 2100000\n}"
              },
              "url": {
                "raw": "http://localhost:5000/api/campaigns/1",
                "protocol": "http",
                "host": ["localhost"],
                "port": "5000",
                "path": ["api", "campaigns", "1"]
              }
            }
          },
          {
            "name": "Delete Campaign (Soft Delete)",
            "request": {
              "method": "DELETE",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{token}}"
                }
              ],
              "url": {
                "raw": "http://localhost:5000/api/campaigns/5",
                "protocol": "http",
                "host": ["localhost"],
                "port": "5000",
                "path": ["api", "campaigns", "5"]
              }
            }
          }
        ]
